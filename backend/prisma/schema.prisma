generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String             @id @default(uuid())
  email              String             @unique
  passwordHash       String             @map("password_hash")
  name               String?
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  // ── legacy one-time payment (kept for backwards compat) ──
  paidAt             DateTime?          @map("paid_at")
  stripeSessionId    String?            @map("stripe_session_id")
  // ── subscription fields ──────────────────────────────────
  stripeCustomerId   String?            @unique @map("stripe_customer_id")
  subscriptionId     String?            @map("subscription_id")
  subscriptionStatus SubscriptionStatus @default(FREE) @map("subscription_status")
  subscriptionEndsAt DateTime?          @map("subscription_ends_at")
  superwallUserId    String?            @map("superwall_user_id")

  account      SimAccount?
  trades       Trade[]
  userMissions UserMission[]
  statsSnaps   StatsSnapshot[]

  @@map("users")
}

// FREE   = no pagó nunca
// ACTIVE = suscripción o lifetime activa
// PAST_DUE = pago fallido, período de gracia
// CANCELLED = canceló, acceso hasta subscriptionEndsAt
// EXPIRED = período terminado
enum SubscriptionStatus {
  FREE
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

model SimAccount {
  id             String   @id @default(uuid())
  userId         String   @unique @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  initialBalance Float    @default(10000) @map("initial_balance")
  currentBalance Float    @default(10000) @map("current_balance")
  equity         Float    @default(10000)
  level          Int      @default(1)
  xp             Int      @default(0)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("sim_accounts")
}

model Trade {
  id           String      @id @default(uuid())
  userId       String      @map("user_id")
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         TradeType
  lot          Float
  entryPrice   Float       @map("entry_price")
  exitPrice    Float?      @map("exit_price")
  sl           Float?
  tp           Float?
  resultUsd    Float?      @map("result_usd")
  resultPct    Float?      @map("result_pct")
  rrRatio      Float?      @map("rr_ratio")
  riskPct      Float?      @map("risk_pct")
  status       TradeStatus @default(OPEN)
  notes        String?
  entryAt      DateTime    @default(now()) @map("entry_at")
  exitAt       DateTime?   @map("exit_at")

  @@map("trades")
}

enum TradeType {
  BUY
  SELL
}

enum TradeStatus {
  OPEN
  CLOSED
  SIMULATED
}

model Mission {
  id           String        @id @default(uuid())
  name         String        @unique
  description  String
  type         MissionType
  targetValue  Float         @map("target_value")
  xpReward     Int           @default(50) @map("xp_reward")
  isDaily      Boolean       @default(false) @map("is_daily")
  userMissions UserMission[]

  @@map("missions")
}

enum MissionType {
  RISK_MAX_PCT
  MIN_RR_RATIO
  TRADES_COUNT
  WIN_STREAK
  NO_REVENGE_TRADE
  MAX_DAILY_LOSS_PCT
}

model UserMission {
  id              String        @id @default(uuid())
  userId          String        @map("user_id")
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  missionId       String        @map("mission_id")
  mission         Mission       @relation(fields: [missionId], references: [id])
  status          MissionStatus @default(ACTIVE)
  currentProgress Float         @default(0) @map("current_progress")
  targetProgress  Float         @map("target_progress")
  assignedAt      DateTime      @default(now()) @map("assigned_at")
  completedAt     DateTime?     @map("completed_at")

  @@unique([userId, missionId])
  @@map("user_missions")
}

enum MissionStatus {
  ACTIVE
  COMPLETED
  FAILED
}

// ─── Trade Desk domain ───────────────────────────────────────────────

model TradeBook {
  id        String            @id @default(uuid())
  name      String
  createdAt DateTime          @default(now()) @map("created_at")
  members   TradeBookMember[]
  orders    TradeOrder[]
  auditLogs TradeAuditLog[]

  @@map("trade_books")
}

model TradeBookMember {
  id        String    @id @default(uuid())
  bookId    String    @map("book_id")
  book      TradeBook @relation(fields: [bookId], references: [id], onDelete: Cascade)
  userEmail String    @map("user_email")
  role      BookRole
  joinedAt  DateTime  @default(now()) @map("joined_at")

  @@unique([bookId, userEmail])
  @@index([bookId])
  @@index([userEmail])
  @@map("trade_book_members")
}

enum BookRole {
  OWNER
  TRADER
  VIEWER
  AUDITOR
}

model TradeOrder {
  id              String      @id @default(uuid())
  bookId          String      @map("book_id")
  book            TradeBook   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  symbol          String      @default("XAUUSD")
  side            DeskSide
  quantity        Float
  price           Float
  status          DeskStatus  @default(DRAFT)
  creatorEmail    String      @map("creator_email")
  approvedByEmail String?     @map("approved_by_email")
  notes           String?
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  auditLogs       TradeAuditLog[]

  @@index([bookId, status])
  @@index([creatorEmail])
  @@map("trade_orders")
}

enum DeskSide {
  BUY
  SELL
}

enum DeskStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

model TradeAuditLog {
  id         String      @id @default(uuid())
  orderId    String?     @map("order_id")
  order      TradeOrder? @relation(fields: [orderId], references: [id], onDelete: SetNull)
  bookId     String      @map("book_id")
  book       TradeBook   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  actorEmail String      @map("actor_email")
  action     String
  detail     String?
  createdAt  DateTime    @default(now()) @map("created_at")

  @@index([bookId])
  @@index([orderId])
  @@map("trade_audit_log")
}

// ─────────────────────────────────────────────────────────────────────

model StatsSnapshot {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date          DateTime @default(now())
  winRate       Float    @map("win_rate")
  avgRisk       Float    @map("avg_risk")
  avgRR         Float    @map("avg_rr")
  winStreak     Int      @map("win_streak")
  lossStreak    Int      @map("loss_streak")
  totalTrades   Int      @map("total_trades")
  totalPnl      Float    @map("total_pnl")
  avgPnlPerTrade Float   @map("avg_pnl_per_trade")

  @@map("stats_snapshots")
}
